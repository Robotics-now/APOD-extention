{
  "manifest_version": 3,
  "name": "NASA APOD Quick Launcher",
  "version": "1.2",
  "description": "Displays today's NASA image from your Streamlit app.",
  "icons": {
    "16": "icon16.png",
    "48": "icon16.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon16.png",
      "128": "icon128.png"
    }
  },
  "permissions": ["tabs"],
  "host_permissions": [
    "https://nasa-apod-api.streamlit.app/*"
  ]
}